{
  "name": "@rotki/action-sqldiff",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "description": "GitHub Actions to add SQLDiffs in pull requests",
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "license": "AGPL-3.0",
  "homepage": "https://github.com/rotki/action-sqldiff",
  "bugs": {
    "url": "https://github.com/rotki/action-sqldiff/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rotki/action-sqldiff"
  },
  "author": "Rotki Solutions GmbH",
  "main": "lib/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "bundle": "pnpm run build && pnpm run package",
    "coverage": "make-coverage-badge --output-path ./badges/coverage.svg",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "package": "ncc build --source-map --license licenses.txt",
    "package:watch": "pnpm run package -- --watch",
    "preinstall": "npx only-allow pnpm",
    "test": "vitest run --coverage",
    "all": "pnpm run lint && pnpm run test && pnpm run coverage && pnpm run package",
    "prepare": "husky",
    "release": "bumpp --no-push"
  },
  "dependencies": {
    "@actions/core": "2.0.1",
    "@actions/github": "6.0.1",
    "micromatch": "4.0.8",
    "semver": "7.7.3"
  },
  "devDependencies": {
    "@commitlint/cli": "20.2.0",
    "@commitlint/config-conventional": "20.2.0",
    "@octokit/types": "16.0.0",
    "@octokit/webhooks-types": "7.6.1",
    "@rotki/eslint-config": "5.0.1",
    "@rotki/eslint-plugin": "1.3.2",
    "@tsconfig/node24": "^24.0.3",
    "@types/micromatch": "4.0.10",
    "@types/node": "25.0.3",
    "@types/semver": "7.7.1",
    "@vercel/ncc": "0.38.4",
    "@vitest/coverage-v8": "4.0.16",
    "bumpp": "10.3.2",
    "eslint": "9.39.2",
"husky": "9.1.7",
    "lint-staged": "16.2.7",
    "make-coverage-badge": "1.2.0",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  },
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <11"
  }
}
