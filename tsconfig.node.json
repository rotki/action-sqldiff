{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true
  },
  "include": [
    "vite.config.*",
    "vitest.config.*",
    "__tests__/**/*.ts"
  ]
}
